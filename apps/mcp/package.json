{
  "name": "@buntime/mcp",
  "version": "1.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "buntime-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "NODE_ENV=production bun scripts/build.ts",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "provision": "bun scripts/provision.ts",
    "provision-prereqs": "bun scripts/provision-prereqs.ts",
    "port-forward": "sh scripts/dev-port-forward.sh",
    "lint": "bun run lint:format && bun run lint:types",
    "lint:format": "bun biome check --write",
    "lint:types": "bun tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@buntime/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8"
  }
}
