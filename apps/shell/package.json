  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch index.dev.ts",
    "build": "NODE_ENV=production bun scripts/build.ts",
    "start": "bun run build && bun dist/index.js",
    "lint": "bun run lint:format && bun run lint:types",
    "lint:format": "bun biome check --write",
    "lint:types": "bun tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@iconify-icon/react": "^3.0.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@zomme/frame": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "keycloak-js": "^26.0.7",
    "lucide-react": "^0.469.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@buntime/shared": "workspace:*",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@zomme/bun-plugin-iconify": "^0.1.2",
    "@zomme/bun-plugin-i18next": "^0.1.1",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.1.18"
  }
}
